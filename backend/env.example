# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
API_VERSION=v1

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://user:password@localhost:5432/topic_similarity?schema=public"

# Shadow database URL for Prisma migrations (optional for managed databases)
# If using a managed database service (like Neon, Supabase), you may need this
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/topic_similarity_shadow?schema=public"

# ============================================
# SBERT Service Configuration
# ============================================
# URL of the SBERT (Sentence-BERT) microservice
SBERT_SERVICE_URL=http://localhost:8000

# Timeout for SBERT service requests (in milliseconds)
SBERT_TIMEOUT=30000

# Number of retry attempts for failed SBERT requests
SBERT_RETRY_ATTEMPTS=3

# ============================================
# Rate Limiting Configuration
# ============================================
# Time window for rate limiting (in milliseconds)
# Default: 900000 (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per IP within the time window
RATE_LIMIT_MAX=100

# ============================================
# CORS Configuration
# ============================================
# Allowed origin for CORS requests
# For development, typically your frontend URL
CORS_ORIGIN=http://localhost:5173

# Allow credentials in CORS requests (true/false)
CORS_CREDENTIALS=true

# ============================================
# Logging Configuration
# ============================================
# Logging level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Log file path (relative to project root)
LOG_FILE=logs/app.log

# ============================================
# Similarity Configuration
# ============================================
# Threshold for Tier 2 similarity (0.0 to 1.0)
# Topics with similarity >= this value are considered Tier 2
SIMILARITY_TIER2_THRESHOLD=0.60

# Time window for Tier 3 similarity check (in hours)
# Topics within this time window are checked for Tier 3 similarity
SIMILARITY_TIER3_TIME_WINDOW_HOURS=48

# ============================================
# Optional: API Keys and Secrets
# ============================================
# Add any API keys or secrets here as needed
# API_KEY=your_api_key_here
# JWT_SECRET=your_jwt_secret_here
