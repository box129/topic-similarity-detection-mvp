// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HistoricalTopic {
  id             Int       @id @default(autoincrement())
  title          String    @db.Text
  keywords       String?   @db.Text
  sessionYear    String    @map("session_year")
  supervisorName String    @map("supervisor_name")
  category       String?
  embedding      Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@index([sessionYear])
  @@index([createdAt])
  @@map("historical_topics")
}

model CurrentSessionTopic {
  id             Int       @id @default(autoincrement())
  title          String    @db.Text
  keywords       String?   @db.Text
  sessionYear    String    @map("session_year")
  supervisorName String    @map("supervisor_name")
  category       String?
  embedding      Json?
  approvedDate   DateTime? @map("approved_date")
  studentId      String?   @map("student_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@index([sessionYear])
  @@index([createdAt])
  @@map("current_session_topics")
}

model UnderReviewTopic {
  id                Int       @id @default(autoincrement())
  title             String    @db.Text
  keywords          String?   @db.Text
  sessionYear       String    @map("session_year")
  supervisorName    String    @map("supervisor_name")
  category          String?
  embedding         Json?
  reviewStartedAt   DateTime? @map("review_started_at")
  reviewingLecturer String?   @map("reviewing_lecturer")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@index([sessionYear])
  @@index([createdAt])
  @@index([reviewStartedAt])
  @@map("under_review_topics")
}
